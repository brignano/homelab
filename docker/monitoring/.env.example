# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# --- Proxmox VE exporter ---
# Create a read-only API token in Proxmox first:
#   Datacenter > Permissions > Users: add  monitoring@pve
#   Datacenter > Permissions > API Tokens: add token for monitoring@pve (uncheck "Privilege Separation")
#   Datacenter > Permissions: add permission  Path "/"  User/Token monitoring@pve!grafana  Role PVEAuditor
PVE_USER=monitoring@pve
PVE_TOKEN_NAME=grafana
PVE_TOKEN_VALUE=replace-with-token-secret

# --- PostgreSQL exporter ---
# Create a read-only monitoring role in the core-stack Postgres first:
#   CREATE ROLE monitoring WITH LOGIN PASSWORD 'strong-password';
#   GRANT pg_monitor TO monitoring;
POSTGRES_EXPORTER_DSN=postgresql://monitoring:strong-password@postgres:5432/postgres?sslmode=disable

# --- ntfy (alert push) ---
# URL the ntfy mobile app subscribes to. Use the LXC tailnet/LAN IP + NTFY_PORT,
# or front ntfy with Caddy and set this to http://alerts.home (preferred).
NTFY_BASE_URL=http://10.0.0.201:8090
NTFY_PORT=8090
