# Memorable, port-free names for homelab services.
#
# Traffic rides the Tailscale tailnet (WireGuard-encrypted at the network
# layer), so we serve plain HTTP — no TLS, no certs, no warnings to manage.
# `auto_https off` keeps Caddy on :80 and stops it trying to provision certs.
#
# To rename a service, edit its site label here and the matching DNS rewrite
# in AdGuard, then `docker compose restart caddy`.

{
	# HTTP-only for the *.home sites (Tailscale already encrypts), but keep cert
	# management on so kali.home can use Caddy's internal CA for HTTPS — the
	# Selkies desktop refuses to run without a secure context. disable_redirects
	# stops the http:// sites from being forced to https.
	auto_https disable_redirects
}

# chat.home  ->  Open WebUI (the AI chat UI; container listens on 8080)
http://chat.home {
	reverse_proxy open-webui:8080
}

# stats.home ->  Grafana
http://stats.home {
	reverse_proxy grafana:3000
}

# apps.home  ->  Portainer (Docker management)
http://apps.home {
	reverse_proxy portainer:9000
}

# dns.home   ->  AdGuard Home admin UI
http://dns.home {
	reverse_proxy adguard:80
}

# alerts.home -> ntfy (push notifications for monitoring alerts)
http://alerts.home {
	reverse_proxy ntfy:80
}

# mcp.home -> Grafana MCP server (read-only metrics/logs/alerts for Claude Code).
# Tailscale is the network boundary; this bearer check is the app-layer guard
# (mcp-grafana has no built-in endpoint auth). The Viewer-scoped Grafana service
# account behind it is the hard read-only ceiling. Token comes from MCP_BEARER_TOKEN
# in docker/proxy/.env. If unset, the matcher rejects everything (fail-closed) and
# only mcp.home is affected — the other sites keep working.
http://mcp.home {
	@noauth not header Authorization "Bearer {env.MCP_BEARER_TOKEN}"
	respond @noauth "Unauthorized" 401

	# flush_interval -1 disables buffering so MCP streamable-HTTP / SSE events
	# reach the client immediately instead of being held by the proxy.
	reverse_proxy mcp-grafana:8000 {
		flush_interval -1
	}
}

# kali.home -> Kali webtop, booted on-demand by Sablier, scaled to zero when idle.
# Served over HTTPS (Caddy internal CA) because the Selkies desktop requires a
# secure context; plain http redirects to https.
http://kali.home {
	redir https://kali.home{uri}
}

https://kali.home {
	tls internal
	route {
		sablier http://sablier:10000 {
			group desktops
			session_duration 30m
			dynamic {
				display_name "Kali Desktop"
				theme hacker-terminal
			}
		}
		reverse_proxy kali-linux:3000
	}
}
